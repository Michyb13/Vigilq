# pnpm's minimumReleaseAge supply-chain check rejects installing a package
# version published very recently. That protection matters when pnpm is
# resolving fresh versions on the fly — it adds little on top of a frozen
# lockfile install, since --frozen-lockfile already pins exact versions via
# integrity hashes checked against what's committed. Disabled here so Docker
# builds stay reproducible instead of failing whenever a pinned dependency
# happens to have been published within the policy's default window.
minimum-release-age=0
