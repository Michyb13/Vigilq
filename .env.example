# Read by docker-compose.yml (Compose loads .env from the same directory
# as the compose file). See docker-compose.yml's header comment for the
# two supported modes.

# --- Database (pick ONE) ---
# Option A: bundled Postgres (run with --profile bundled-db)
# DATABASE_URL=postgres://postgres:postgres@db:5432/vigilq
# POSTGRES_DB=vigilq
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# Option B: your own existing Postgres instance
DATABASE_URL=postgres://user:password@your-postgres-host:5432/your-db

# --- AI triage provider (pick ONE, BYOK) ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=
GOOGLE_API_KEY=
GOOGLE_MODEL=

# --- Sweeper schedule (node-cron expression, supports seconds) ---
SWEEP_CRON_SCHEDULE=*/10 * * * * *
