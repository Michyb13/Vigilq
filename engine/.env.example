# --- Database (pick ONE) ---
# Option A: bundled Postgres from docker-compose.yml's "db" service
#   (only reachable if you ran `docker compose --profile bundled-db up`)
# DATABASE_URL=postgres://postgres:postgres@db:5432/vigilq
#
# Option B: your own existing Postgres instance — local, RDS, Supabase,
#   wherever. The engine doesn't care, it's just a connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vigilq

# --- AI triage provider (pick ONE, BYOK) ---
# Leave the chosen provider's key/model unset to disable triage entirely.
AI_PROVIDER=anthropic

# anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# openai (no default model — set explicitly, see OpenAI's current model list)
OPENAI_API_KEY=
OPENAI_MODEL=

# google (no default model — set explicitly, see Gemini's current model list)
GOOGLE_API_KEY=
GOOGLE_MODEL=
